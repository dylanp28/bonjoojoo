                        }}
                      />
                    </motion.div>
                    <div>
                      <h3 className="font-semibold text-black">{feature}</h3>
                    </div>
                  </motion.div>
                </PandoraStaggerItem>
              ))}
            </PandoraStaggerGrid>
          </div>
        </section>
