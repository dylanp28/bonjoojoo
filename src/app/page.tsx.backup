              >
                PANDORA MINIS STYLED BY KATSEYE
              </PandoraText>
              
              <PandoraButton 
                variant="primary"
                className="mt-4"
              >
                SHOP NOW
              </PandoraButton>
            </motion.div>
          </div>

          {/* Animated Promotional Banner */}
          <motion.div
            className="absolute bottom-0 left-0 right-0 bg-white bg-opacity-95 px-8 py-6"
            initial={{ y: 100, opacity: 0 }}
            animate={{ y: 0, opacity: 1 }}
            transition={{ duration: 0.8, delay: 1.5 }}
          >
            <div className="max-w-7xl mx-auto flex items-center justify-between">
              <div className="flex-1">
                <motion.p
                  className="text-sm font-bold text-pink-600 mb-2"
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  transition={{ duration: 0.6, delay: 1.8 }}
                >
                  LIMITED TIME ONLY!
                </motion.p>
                <motion.p
                  className="text-lg font-semibold text-black"
                  initial={{ opacity: 0, y: 20 }}
                  animate={{ opacity: 1, y: 0 }}
                  transition={{ duration: 0.6, delay: 2 }}
                >
                  15% off select bracelets when you buy 2 charms
                </motion.p>
                <motion.p
                  className="text-sm text-gray-600"
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 1 }}
                  transition={{ duration: 0.6, delay: 2.2 }}
                >
                  <Link href="#" className="underline hover:text-black transition-colors">Terms & Conditions</Link> apply.
                </motion.p>
              </div>
              <PandoraButton variant="primary">
                SHOP CHARMS
              </PandoraButton>
            </div>
          </motion.div>
        </PandoraHeroSection>

        {/* ANIMATED CATEGORY SECTION */}
        <section className="py-16 bg-white">
          <div className="max-w-7xl mx-auto px-8">
            <motion.div
              className="text-center mb-12"
              initial={{ opacity: 0, y: 50 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true, margin: '-100px' }}
              transition={{ duration: 0.8, ease: [0.25, 0.46, 0.45, 0.94] }}
            >
              <p className="text-lg text-gray-600 mb-4">Find what speaks to you</p>
              <motion.h2
                className="text-5xl font-bold text-black"
                initial={{ scale: 0.9 }}
                whileInView={{ scale: 1 }}
                viewport={{ once: true }}
                transition={{ duration: 0.6, delay: 0.2 }}
              >
                <motion.span
                  className="bg-red-500 text-white px-4 py-2 rounded"
                  whileHover={{
                    scale: 1.05,
                    rotate: [-1, 1, -1, 0],
                    transition: { duration: 0.5 }
                  }}
                >
                  Sale 30% Off
                </motion.span>
              </motion.h2>
            </motion.div>

            {/* Animated Category Grid */}
            <PandoraStaggerGrid className="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
              {[
                { name: 'Charms', href: '/charms', emoji: '🌟' },
                { name: 'Bracelets', href: '/bracelets', emoji: '💎' },
                { name: 'Rings', href: '/rings', emoji: '💍' },
                { name: 'Necklaces', href: '/necklaces', emoji: '📿' }
              ].map((category) => (
                <PandoraStaggerItem key={category.name}>
                  <PandoraProductCard href={category.href}>
                    <div className="aspect-square bg-gray-200 rounded-lg mb-4 flex items-center justify-center border-2 border-dashed border-gray-400 group-hover:border-gray-600 transition-colors duration-300">
                      <motion.div
                        className="text-center text-gray-600"
                        whileHover={{ scale: 1.1 }}
                        transition={{ duration: 0.3 }}
                      >
                        <motion.div
                          className="text-6xl mb-2"
                          animate={{
                            rotate: [0, 10, -10, 0]
                          }}
                          transition={{
                            duration: 2,
                            repeat: Infinity,
                            ease: "easeInOut"
                          }}
                        >
                          {category.emoji}
                        </motion.div>
                        <p className="text-sm font-medium">{category.name} Image</p>
                        <p className="text-xs text-gray-500">Product Photo</p>
                      </motion.div>
                    </div>
                    <h3 className="text-xl font-bold text-black group-hover:text-gray-700 transition-colors duration-300">
                      {category.name}
                    </h3>
                  </PandoraProductCard>
                </PandoraStaggerItem>
