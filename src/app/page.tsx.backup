              {
                title: 'RESOURCES',
                links: ['Blog', 'Size Guide', 'Care Guide']
              },
              {
                title: 'SERVICES',
                links: ['Engraving', 'Gift Cards', 'Warranty', 'Repairs']
              },
              {
                title: 'LEGAL',
                links: ['Privacy Policy', 'Terms of Service', 'Returns']
              },
              {
                title: 'ABOUT US',
                links: ['Our Story', 'Sustainability', 'Careers']
              }
