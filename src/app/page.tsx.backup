                        <div className="text-center text-gray-700">
                          <PandoraText className="text-2xl font-bold mb-2">KATSEYE</PandoraText>
                          <PandoraText className="text-sm" delay={0.5}>MINIS</PandoraText>
                        </div>
                      </motion.div>
                    </div>
                  </motion.div>
                  
                  {/* Floating elements with continuous animation */}
                  <motion.div
                    className="absolute -top-4 -left-4 w-12 h-12 bg-purple-400 rounded-full shadow-xl opacity-70"
                    animate={{
                      y: [-10, 10, -10],
                      rotate: [0, 360],
                      scale: [0.8, 1.2, 0.8]
                    }}
                    transition={{
                      duration: 4,
                      repeat: Infinity,
                      ease: "easeInOut"
                    }}
                  />
                  <motion.div
                    className="absolute -bottom-4 -right-4 w-8 h-8 bg-pink-400 rounded-full shadow-xl opacity-70"
