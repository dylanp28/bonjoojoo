              whileTap={{ scale: 0.95 }}
            >
              {videoStates.katseye.muted ? <VolumeX className="w-6 h-6" /> : <Volume2 className="w-6 h-6" />}
            </motion.button>
          </motion.div>

          {/* Animated Content */}
          <div className="max-w-7xl mx-auto px-8 w-full">
            <motion.div
