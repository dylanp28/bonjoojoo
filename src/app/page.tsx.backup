'use client'

import { useState, useRef, useEffect } from 'react'
import { Search, Heart, MapPin, User, ShoppingBag, Play, Pause, VolumeX, Volume2, ChevronDown } from 'lucide-react'
import Link from 'next/link'
import { motion } from 'framer-motion'
import {
  usePandoraHeaderScroll,
  PandoraProductCard,
  PandoraHeroSection,
  PandoraButton,
  PandoraStaggerGrid,
  PandoraStaggerItem,
  ScrollProgress,
  PandoraText,
  PandoraNavigation
} from '../components/PandoraAnimations'
import {
  EnhancedNewFeaturedMegaMenu,
  EnhancedShopByMegaMenu,
  EnhancedCharmsMegaMenu
} from '../components/EnhancedPandoraMegaMenu'
import {
  PandoraWishlistHeart,
  PandoraShoppingBag,
  PandoraSearchBar,
  PandoraProductImage,
  PandoraPrice
} from '../components/PandoraMicroInteractions'

export default function PandoraAnimatedHomePage() {
  const [currentSlide, setCurrentSlide] = useState(0)
  const [videoStates, setVideoStates] = useState({
    katseye: { playing: true, muted: true },
    bestsellers: { playing: false, muted: true },
    engraving: { playing: false, muted: true },
    disney: { playing: false, muted: true }
  })

  // Use Pandora header scroll hook
  const { headerRef, logoRef, headerStyle, logoStyle } = usePandoraHeaderScroll()
  
  const toggleVideo = (section: keyof typeof videoStates) => {
    setVideoStates(prev => ({
      ...prev,
      [section]: { ...prev[section], playing: !prev[section].playing }
    }))
  }

  const toggleMute = (section: keyof typeof videoStates) => {
    setVideoStates(prev => ({
      ...prev,
      [section]: { ...prev[section], muted: !prev[section].muted }
    }))
  }

  return (
    <div className="min-h-screen bg-white">
      {/* Scroll Progress Indicator */}
      <ScrollProgress />
      
      {/* ANIMATED HEADER WITH PANDORA SCROLL BEHAVIOR */}
      <motion.header
        ref={headerRef}
        className="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent"
        style={headerStyle}
      >
        <div className="flex items-center justify-between px-6 py-4 max-w-7xl mx-auto">
          {/* Animated Logo */}
          <Link href="/" className="flex-shrink-0">
            <motion.div
              ref={logoRef}
              className="text-2xl font-bold text-black tracking-wide origin-center"
              style={logoStyle}
              whileHover={{ scale: 1.05 }}
              transition={{ duration: 0.2 }}
            >
              BONJOOJOO
            </motion.div>
          </Link>

          {/* Animated Navigation */}
          <PandoraNavigation className="hidden lg:flex items-center space-x-8 text-sm font-medium">
            {[
              { name: 'New & featured', href: '/new-featured' },
              { name: 'Shop by', href: '/shop-by' },
              { name: 'Charms', href: '/charms' },
              { name: 'Bracelets', href: '/bracelets' },
              { name: 'Necklaces', href: '/necklaces' },
              { name: 'Rings', href: '/rings' },
              { name: 'Earrings', href: '/earrings' },
              { name: 'Lab-grown diamonds', href: '/lab-grown-diamonds' },
              { name: 'Engraving', href: '/engraving' },
              { name: 'Gifts', href: '/gifts' },
              { name: 'Collections', href: '/collections' }
            ].map((item, index) => (
              <motion.div key={item.href}>
                <Link 
                  href={item.href} 
                  className="text-black hover:text-gray-600 relative group"
                >
                  {item.name}
                  {/* Animated underline */}
                  <motion.div
                    className="absolute -bottom-1 left-0 h-0.5 bg-black"
                    initial={{ width: 0 }}
                    whileHover={{
                      width: '100%',
                      transition: { duration: 0.3, ease: [0.25, 0.46, 0.45, 0.94] }
                    }}
                  />
                </Link>
              </motion.div>
            ))}
          </PandoraNavigation>

          {/* Animated Right Side Icons */}
          <motion.div 
            className="flex items-center space-x-4"
            initial={{ opacity: 0, x: 50 }}
            animate={{ opacity: 1, x: 0 }}
            transition={{ duration: 0.8, delay: 0.4 }}
          >
            {/* Search with Animation */}
            <div className="hidden md:block">
              <motion.div
                className="relative"
                whileHover={{ scale: 1.02 }}
                transition={{ duration: 0.2 }}
              >
                <input 
                  type="text" 
                  placeholder="Search"
                  className="w-80 pl-4 pr-12 py-3 border border-gray-300 rounded-full text-sm focus:outline-none focus:ring-1 focus:ring-gray-400 transition-all duration-300 focus:border-black"
                />
                <Search className="absolute right-4 top-3.5 w-5 h-5 text-gray-400" />
              </motion.div>
            </div>

            {/* Animated Icons */}
            {[Heart, MapPin, User, ShoppingBag].map((Icon, index) => (
