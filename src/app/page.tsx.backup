                  <motion.h3
                    className="font-bold text-black mb-4 text-sm tracking-wider"
                    initial={{ opacity: 0, x: -20 }}
                    whileInView={{ opacity: 1, x: 0 }}
                    viewport={{ once: true }}
                    transition={{ duration: 0.6, delay: columnIndex * 0.1 }}
                  >
                    {column.title}
                  </motion.h3>
                  <motion.ul className="space-y-3 text-sm">
                    {column.links.map((link, linkIndex) => (
                      <motion.li
                        key={link}
                        initial={{ opacity: 0, x: -20 }}
                        whileInView={{ opacity: 1, x: 0 }}
                        viewport={{ once: true }}
                        transition={{
                          duration: 0.6,
                          delay: (columnIndex * 0.1) + (linkIndex * 0.05)
                        }}
                      >
                        <Link
                          href={`/${link.toLowerCase().replace(/\s+/g, '-')}`}
                          className="text-gray-600 hover:text-black transition-colors duration-200 relative group"
                        >
                          {link}
                          <motion.div
                            className="absolute -bottom-1 left-0 h-px bg-black"
                            initial={{ width: 0 }}
                            whileHover={{
                              width: '100%',
                              transition: { duration: 0.3 }
                            }}
                          />
                        </Link>
                      </motion.li>
                    ))}
                  </motion.ul>
                </motion.div>
              </PandoraStaggerItem>
            ))}
          </PandoraStaggerGrid>

          {/* Animated Bottom Footer */}
          <motion.div
