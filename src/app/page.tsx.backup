                key={index}
                className="p-2 hover:bg-gray-100 rounded-full transition-colors duration-200"
                whileHover={{ 
                  scale: 1.1,
                  rotate: index === 0 ? 5 : 0 // Heart gets a little rotation
                }}
                whileTap={{ scale: 0.95 }}
                initial={{ opacity: 0, y: -20 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ duration: 0.6, delay: 0.5 + index * 0.1 }}
              >
                <Icon className="w-5 h-5" />
              </motion.button>
            ))}
          </motion.div>
        </div>
      </motion.header>

      <main className="pt-20">
        {/* HERO SECTION 1: ANIMATED KATSEYE */}
        <PandoraHeroSection className="bg-gradient-to-br from-purple-100 via-pink-50 to-gold-100">
          {/* Enhanced Jewelry Visualization with Animations */}
          <motion.div 
            className="absolute inset-0"
            initial={{ scale: 1.1, opacity: 0 }}
            animate={{ scale: 1, opacity: 0.8 }}
            transition={{ duration: 2, ease: [0.25, 0.46, 0.45, 0.94] }}
          >
            {/* Background with jewelry-inspired gradient */}
            <div className="absolute inset-0 bg-gradient-to-br from-purple-200 via-pink-100 to-yellow-100 opacity-80"></div>
            
            {/* Animated jewelry representation */}
            <div className="absolute inset-0 flex items-center justify-end pr-32">
              <motion.div 
                className="relative"
                initial={{ scale: 0, rotate: -180 }}
                animate={{ scale: 1, rotate: 0 }}
                transition={{ duration: 1.5, ease: [0.34, 1.56, 0.64, 1], delay: 0.5 }}
              >
                {/* Main jewelry piece visualization */}
                <div className="w-96 h-96 relative">
                  {/* Animated charm bracelet visualization */}
                  <motion.div
                    className="absolute inset-0 rounded-full border-8 border-gold-400 bg-gradient-to-br from-gold-100 to-gold-200 shadow-2xl"
                    animate={{
                      rotate: 360,
                      scale: [1, 1.02, 1]
                    }}
                    transition={{
                      rotate: { duration: 20, repeat: Infinity, ease: "linear" },
                      scale: { duration: 3, repeat: Infinity, ease: "easeInOut" }
                    }}
                  >
                    <div className="absolute inset-4 rounded-full bg-gradient-to-br from-white to-pink-50">
                      {/* Animated mini charms around the circle */}
                      {[
                        { top: 8, left: '50%', color: 'purple', delay: 0 },
                        { top: '50%', right: 8, color: 'pink', delay: 0.2 },
                        { bottom: 8, left: '50%', color: 'yellow', delay: 0.4 },
                        { top: '50%', left: 8, color: 'blue', delay: 0.6 }
                      ].map((charm, index) => (
                        <motion.div
                          key={index}
                          className={`absolute w-8 h-8 bg-${charm.color}-300 rounded-full shadow-lg transform -translate-x-1/2 -translate-y-1/2`}
                          style={{
                            top: charm.top,
                            right: charm.right,
                            bottom: charm.bottom,
                            left: charm.left
                          }}
                          animate={{
                            scale: [1, 1.3, 1],
                            rotate: [0, 180, 360]
                          }}
                          transition={{
                            duration: 2,
                            repeat: Infinity,
                            delay: charm.delay,
                            ease: "easeInOut"
                          }}
                        />
                      ))}
                      
                      {/* Center text with animation */}
                      <motion.div
                        className="absolute inset-0 flex items-center justify-center"
                        initial={{ opacity: 0 }}
                        animate={{ opacity: 1 }}
