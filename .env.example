# Bonjoojoo Environment Configuration

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bonjoojoo"
DATABASE_SECRET_KEY="your-32-character-secret-key-here"

# Authentication
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# Stripe Payment Processing
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Email Services
KLAVIYO_API_KEY="your-klaviyo-private-api-key"
KLAVIYO_PUBLIC_KEY="your-klaviyo-public-api-key"
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
EMAIL_FROM="noreply@bonjoojoo.com"

# Analytics & Tracking
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
FACEBOOK_PIXEL_ID="your-facebook-pixel-id"
GOOGLE_TAG_MANAGER_ID="GTM-XXXXXXX"

# Security & Performance
SECURITY_HEADER_SECRET="your-security-secret"
RATE_LIMIT_SECRET="your-rate-limit-secret"
ENCRYPTION_KEY="your-32-byte-encryption-key"

# External APIs
GIA_API_KEY="your-gia-api-key"
IGI_API_KEY="your-igi-api-key"

# Monitoring
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"

# Redis (for caching and sessions)
REDIS_URL="redis://localhost:6379"

# Production Settings
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Image Optimization
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Search (if using Algolia/Elasticsearch)
ALGOLIA_APP_ID="your-algolia-app-id"
ALGOLIA_API_KEY="your-algolia-api-key"
ALGOLIA_SEARCH_KEY="your-algolia-search-key"

# Customer Support
INTERCOM_APP_ID="your-intercom-app-id"
ZENDESK_SUBDOMAIN="your-zendesk-subdomain"
ZENDESK_API_TOKEN="your-zendesk-api-token"