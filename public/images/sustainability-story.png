<svg width="400" height="300" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
  <rect width="400" height="300" fill="#f5f5f4"/>
  <rect x="20" y="20" width="360" height="260" rx="8" fill="white" stroke="#d6d3d1" stroke-width="2"/>
  
  <!-- Earth/Leaf Icon -->
  <circle cx="200" cy="120" r="40" fill="#16a34a" opacity="0.2"/>
  <path d="M180 120 Q190 100 210 110 Q220 120 210 140 Q200 150 180 140 Q170 130 180 120" fill="#16a34a" opacity="0.7"/>
  <path d="M190 130 Q195 125 200 130 Q205 135 210 130" stroke="#16a34a" stroke-width="2" fill="none"/>
  
  <!-- Water Drop -->
  <path d="M160 160 Q160 150 170 150 Q180 150 180 160 Q180 170 170 175 Q160 170 160 160" fill="#0ea5e9" opacity="0.6"/>
  
  <!-- CO2 Reduction Arrow -->
  <path d="M220 160 L240 150 L240 170 Z" fill="#dc2626" opacity="0.6"/>
  <line x1="220" y1="160" x2="235" y2="160" stroke="#dc2626" stroke-width="2"/>
  <text x="250" y="165" font-family="sans-serif" font-size="12" fill="#dc2626">-95%</text>
  
  <!-- Sustainability Label */
  <text x="200" y="260" text-anchor="middle" font-family="serif" font-size="14" fill="#0c0a09" opacity="0.6">
    Sustainability Story
  </text>
</svg>