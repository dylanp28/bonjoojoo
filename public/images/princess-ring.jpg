<svg width="600" height="600" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
  <rect width="600" height="600" fill="#f8fafc"/>
  <rect x="30" y="30" width="540" height="540" rx="12" fill="white" stroke="#e2e8f0" stroke-width="2"/>
  
  <!-- Ring -->
  <circle cx="300" cy="300" r="120" fill="none" stroke="#1e293b" stroke-width="6" opacity="0.8"/>
  
  <!-- Princess Cut Diamond (Square) -->
  <rect x="280" y="230" width="40" height="40" fill="#1e293b" opacity="0.8" transform="rotate(45 300 250)"/>
  <rect x="285" y="235" width="30" height="30" fill="#f1f5f9" transform="rotate(45 300 250)"/>
  <rect x="290" y="240" width="20" height="20" fill="#1e293b" opacity="0.4" transform="rotate(45 300 250)"/>
  
  <!-- Ring Band Details -->
  <rect x="285" y="420" width="30" height="12" rx="6" fill="#1e293b" opacity="0.4"/>
  <rect x="290" y="408" width="20" height="8" rx="4" fill="#1e293b" opacity="0.3"/>
  
  <!-- Side Stones -->
  <circle cx="240" cy="270" r="6" fill="#1e293b" opacity="0.6"/>
  <circle cx="360" cy="270" r="6" fill="#1e293b" opacity="0.6"/>
  
  <!-- Sparkle Effects -->
  <circle cx="350" cy="200" r="3" fill="#fbbf24" opacity="0.8"/>
  <circle cx="250" cy="220" r="2" fill="#fbbf24" opacity="0.6"/>
  <circle cx="330" cy="180" r="2" fill="#fbbf24" opacity="0.7"/>
  
  <!-- Product Info -->
  <text x="300" y="520" text-anchor="middle" font-family="serif" font-size="24" fill="#1e293b" opacity="0.7">
    Princess Cut Ring
  </text>
  <text x="300" y="550" text-anchor="middle" font-family="sans-serif" font-size="16" fill="#64748b">
    Lab-Grown • GIA Certified
  </text>
</svg>