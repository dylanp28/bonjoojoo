<svg width="400" height="400" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
  <rect width="400" height="400" fill="#f5f5f4"/>
  <rect x="20" y="20" width="360" height="360" rx="8" fill="white" stroke="#d6d3d1" stroke-width="2"/>
  
  <!-- Diamond Ring -->
  <circle cx="200" cy="200" r="80" fill="none" stroke="#0c0a09" stroke-width="4" opacity="0.7"/>
  
  <!-- Diamond -->
  <path d="M200 140 L220 170 L200 200 L180 170 Z" fill="#0c0a09" opacity="0.7"/>
  <path d="M200 150 L210 170 L200 190 L190 170 Z" fill="white" opacity="0.9"/>
  
  <!-- Ring Band Details -->
  <rect x="185" y="280" width="30" height="8" rx="4" fill="#0c0a09" opacity="0.3"/>
  <rect x="190" y="272" width="20" height="6" rx="3" fill="#0c0a09" opacity="0.2"/>
  
  <!-- bonjoojoo branding -->
  <text x="200" y="350" text-anchor="middle" font-family="serif" font-size="16" fill="#0c0a09" opacity="0.4">
    bonjoojoo
  </text>
  <text x="200" y="370" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#0c0a09" opacity="0.3">
    Lab-Grown Diamond
  </text>
</svg>