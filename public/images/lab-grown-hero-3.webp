<svg width="1920" height="800" viewBox="0 0 1920 800" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="heroGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5f5f4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e7e5e4;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="1920" height="800" fill="url(#heroGradient)"/>
  
  <!-- Hero Diamond -->
  <g transform="translate(960,400)">
    <path d="M0,-150 L100,-50 L0,150 L-100,-50 Z" fill="#0c0a09" opacity="0.1"/>
    <path d="M0,-120 L80,-40 L0,120 L-80,-40 Z" fill="#0c0a09" opacity="0.7"/>
    <path d="M0,-90 L60,-30 L0,90 L-60,-30 Z" fill="white" opacity="0.8"/>
    <path d="M0,-60 L40,-20 L0,60 L-40,-20 Z" fill="#0c0a09" opacity="0.3"/>
  </g>
  
  <!-- Brand Text -->
  <text x="960" y="580" text-anchor="middle" font-family="serif" font-size="48" fill="#0c0a09" opacity="0.8">
    bonjoojoo
  </text>
  <text x="960" y="630" text-anchor="middle" font-family="sans-serif" font-size="24" fill="#0c0a09" opacity="0.6">
    Lab-Grown Diamond Jewelry
  </text>
  <text x="960" y="670" text-anchor="middle" font-family="sans-serif" font-size="16" fill="#0c0a09" opacity="0.5">
    Sustainable Luxury • Los Angeles
  </text>
</svg>