<svg width="600" height="600" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg">
  <rect width="600" height="600" fill="#f8fafc"/>
  <rect x="30" y="30" width="540" height="540" rx="12" fill="white" stroke="#e2e8f0" stroke-width="2"/>
  
  <!-- Tennis Bracelet Chain -->
  <path d="M150 300 Q200 250 250 300 Q300 350 350 300 Q400 250 450 300" 
        fill="none" stroke="#1e293b" stroke-width="8" opacity="0.8"/>
  
  <!-- Diamonds on Bracelet -->
  <circle cx="180" cy="275" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="180" cy="275" r="5" fill="#f1f5f9"/>
  
  <circle cx="220" cy="290" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="220" cy="290" r="5" fill="#f1f5f9"/>
  
  <circle cx="260" cy="310" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="260" cy="310" r="5" fill="#f1f5f9"/>
  
  <circle cx="300" cy="330" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="300" cy="330" r="5" fill="#f1f5f9"/>
  
  <circle cx="340" cy="310" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="340" cy="310" r="5" fill="#f1f5f9"/>
  
  <circle cx="380" cy="290" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="380" cy="290" r="5" fill="#f1f5f9"/>
  
  <circle cx="420" cy="275" r="8" fill="#1e293b" opacity="0.8"/>
  <circle cx="420" cy="275" r="5" fill="#f1f5f9"/>
  
  <!-- Clasp Detail -->
  <rect x="440" y="295" width="20" height="10" rx="5" fill="#1e293b" opacity="0.6"/>
  
  <!-- Sparkle Effects -->
  <circle cx="200" cy="250" r="3" fill="#fbbf24" opacity="0.8"/>
  <circle cx="320" cy="280" r="2" fill="#fbbf24" opacity="0.6"/>
  <circle cx="360" cy="260" r="2" fill="#fbbf24" opacity="0.7"/>
  <circle cx="280" cy="350" r="2" fill="#fbbf24" opacity="0.6"/>
  
  <!-- Product Info -->
  <text x="300" y="520" text-anchor="middle" font-family="serif" font-size="24" fill="#1e293b" opacity="0.7">
    Tennis Bracelet
  </text>
  <text x="300" y="550" text-anchor="middle" font-family="sans-serif" font-size="16" fill="#64748b">
    Lab-Grown Diamonds • Premium Quality
  </text>
</svg>